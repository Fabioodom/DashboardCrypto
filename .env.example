# CryptoVision Dashboard - Variables de Entorno
# Copia este archivo como .env y configura tus valores

# API Configuration
# CoinGecko no requiere API key para uso básico
# Si necesitas acceso premium, registra tu key aquí
COINGECKO_API_KEY=

# Application Settings
APP_ENV=development
APP_NAME=CryptoVision Dashboard
APP_VERSION=1.0.0

# Rate Limiting (opcional, valores por defecto ya definidos)
# RATE_LIMIT_CALLS=10
# RATE_LIMIT_WINDOW=60000

# Cache Duration (en milisegundos)
# CACHE_DURATION=300000

# Demo Credentials (NO modificar - solo para desarrollo)
DEMO_USERNAME=admin
DEMO_PASSWORD=demo123